{
  "name": "@tenbaselabs/tensor",
  "version": "0.1.0",
  "description": "Multi-brand design system for TENbase Labs products",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "npm run build:tokens && tsc && vite build",
    "build:tokens": "style-dictionary build --config sd.roundvision.config.js && style-dictionary build --config sd.tenbase.config.js",
    "preview": "vite preview",
    "storybook": "storybook dev -p 6006",
    "build-storybook": "storybook build",
    "test": "vitest",
    "lint": "biome check --write .",
    "lint:check": "biome check .",
    "typecheck": "tsc --noEmit",
    "argos": "argos upload ./storybook-static --token=$ARGOS_TOKEN",
    "create-component": "node scripts/create-component.js"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/TENbase-Labs/tensor.git"
  },
  "keywords": [
    "design-system",
    "react",
    "tailwind",
    "storybook"
  ],
  "author": "TENbase Labs",
  "license": "MIT",
  "peerDependencies": {
    "react": "^19.2.3",
    "react-dom": "^19.2.3"
  },
  "devDependencies": {
    "@argos-ci/cli": "4.1.1",
    "@argos-ci/storybook": "5.2.14",
    "@biomejs/biome": "2.4.6",
    "@chromatic-com/storybook": "^5.0.1",
    "@radix-ui/react-checkbox": "1.3.3",
    "@radix-ui/react-dialog": "1.1.15",
    "@radix-ui/react-radio-group": "1.3.8",
    "@radix-ui/react-select": "2.2.6",
    "@radix-ui/react-switch": "1.2.6",
    "@radix-ui/react-tooltip": "1.2.8",
    "@semantic-release/changelog": "^6.0.3",
    "@semantic-release/commit-analyzer": "^13.0.0",
    "@semantic-release/git": "^10.0.1",
    "@semantic-release/github": "^11.0.0",
    "@semantic-release/npm": "^13.0.0",
    "@semantic-release/release-notes-generator": "^14.0.0",
    "@storybook/addon-a11y": "^10.2.15",
    "@storybook/addon-docs": "^10.2.15",
    "@storybook/addon-onboarding": "^10.2.15",
    "@storybook/addon-vitest": "^10.2.15",
    "@storybook/react-vite": "^10.2.15",
    "@tailwindcss/vite": "4.2.1",
    "@testing-library/jest-dom": "6.9.1",
    "@testing-library/react": "16.3.2",
    "@testing-library/user-event": "14.6.1",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.1.4",
    "@vitest/browser-playwright": "^4.0.18",
    "@vitest/coverage-v8": "^4.0.18",
    "class-variance-authority": "0.7.1",
    "conventional-changelog-conventionalcommits": "^8.0.0",
    "jsdom": "28.1.0",
    "playwright": "^1.58.2",
    "semantic-release": "^24.0.0",
    "storybook": "^10.2.15",
    "style-dictionary": "5.3.3",
    "tailwindcss": "4.2.1",
    "typescript": "^5.9.3",
    "vite": "^6.4.1",
    "vitest": "^4.0.18"
  }
}
