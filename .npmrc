# NPM Configuration

# Bind @tenbaselabs scope to npm registry
@tenbaselabs:registry=https://registry.npmjs.org/

# Default registry (for non-scoped packages)
registry=https://registry.npmjs.org/

# Save exact versions (no ^ or ~)
save-exact=true

# Use package-lock for deterministic installs
package-lock=true

# Access level for publishing (public for open source)
access=public
